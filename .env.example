# Copy to .env.local and fill in. (Used for local dev. For production, see docs/VERCEL.md.)

# --- Wajib (publishable key aman untuk browser, dijaga RLS) ---
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_xxxxxxxxxxxxxxxx

# --- Opsional: Android TWA / verified app links (route /.well-known/assetlinks.json) ---
# TWA_PACKAGE_NAME=com.evertahumanics.sefine
# TWA_SHA256_FINGERPRINT=

# --- Edge Function secrets — set via `supabase secrets set NAME=value` (BUKAN di file ini) ---
# SUPABASE_SERVICE_ROLE_KEY=
# WA_VERIFY_TOKEN=
# WA_APP_SECRET=
# WA_ACCESS_TOKEN=
# WA_PHONE_NUMBER_ID=

# Catatan: kunci AI provider (Anthropic / OpenAI / 9router) BUKAN env var —
# diisi lewat UI (Pengaturan → Integrasi → Provider AI), tersimpan terenkripsi di DB.
